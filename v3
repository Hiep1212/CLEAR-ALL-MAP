local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

-- remote
local function activateV3()
    local args = {
        "ActivateAbility"
    }

    ReplicatedStorage:WaitForChild("Remotes")
        :WaitForChild("CommE")
        :FireServer(unpack(args))
end

-- xóa gui cũ nếu có
local oldGui = PlayerGui:FindFirstChild("V3Gui")
if oldGui then
    oldGui:Destroy()
end

-- tạo gui
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "V3Gui"
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = PlayerGui

-- frame chính
local MainFrame = Instance.new("Frame")
MainFrame.Parent = ScreenGui
MainFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
MainFrame.BorderSizePixel = 0
MainFrame.Position = UDim2.new(0, 10, 0, 10)
MainFrame.Size = UDim2.new(0, 180, 0, 90)

local UICorner = Instance.new("UICorner")
UICorner.CornerRadius = UDim.new(0, 8)
UICorner.Parent = MainFrame

-- title
local Title = Instance.new("TextLabel")
Title.Parent = MainFrame
Title.BackgroundTransparency = 1
Title.Position = UDim2.new(0, 0, 0, 6)
Title.Size = UDim2.new(1, 0, 0, 24)
Title.Font = Enum.Font.GothamBold
Title.Text = "V3 Control"
Title.TextColor3 = Color3.fromRGB(255, 255, 255)
Title.TextSize = 16

-- nút bật v3
local V3Button = Instance.new("TextButton")
V3Button.Parent = MainFrame
V3Button.BackgroundColor3 = Color3.fromRGB(0, 170, 127)
V3Button.BorderSizePixel = 0
V3Button.Position = UDim2.new(0, 15, 0, 40)
V3Button.Size = UDim2.new(1, -30, 0, 35)
V3Button.Font = Enum.Font.GothamBold
V3Button.Text = "Bật V3"
V3Button.TextColor3 = Color3.fromRGB(255, 255, 255)
V3Button.TextSize = 16

local ButtonCorner = Instance.new("UICorner")
ButtonCorner.CornerRadius = UDim.new(0, 6)
ButtonCorner.Parent = V3Button

-- click
V3Button.MouseButton1Click:Connect(function()
    V3Button.Text = "Đang bật..."
    
    pcall(function()
        activateV3()
    end)

    task.wait(0.5)
    V3Button.Text = "Bật V3"
end)
