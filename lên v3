Status.TextColor3 = Color3.fromRGB(200, 200, 200)
Status.TextSize = 14
Status.Font = Enum.Font.SourceSans

BtnQuest.MouseButton1Click:Connect(function()
    local ok, result = pcall(NhanNhiemVu)
    print("Nhận nhiệm vụ:", ok and result or "Lỗi")
end)

BtnBuy.MouseButton1Click:Connect(function()
    local ok, result = pcall(MuaTocV3)
    print("Mua V3:", ok and result or "Lỗi")
end)

task.spawn(function()
    local daNhanQuest = false

    local ok, result = pcall(NhanNhiemVu)
    if ok then
        print("Nhận nhiệm vụ:", result)

        if DaNhanQuestThanhCong(result) then
            daNhanQuest = true
            Status.Text = "Trạng thái: Đã nhận nhiệm vụ"
            print("Đã nhận nhiệm vụ, sẽ không nhận lại nữa.")
        else
            Status.Text = "Trạng thái: Chưa nhận được nhiệm vụ"
        end
    else
        Status.Text = "Trạng thái: Lỗi khi nhận nhiệm vụ"
    end

    while task.wait(3) do
        if daNhanQuest then
            local okBuy, buyResult = pcall(MuaTocV3)
            if okBuy then
                print("Thử mua V3:", buyResult)

                if DaMuaV3ThanhCong(buyResult) then
                    Status.Text = "Trạng thái: Đã mua V3"
                    print("Mua V3 thành công, dừng script.")
                    break
                else
                    Status.Text = "Trạng thái: Chưa đủ điều kiện mua V3"
                end
            else
                Status.Text = "Trạng thái: Lỗi khi thử mua V3"
            end
        else
            Status.Text = "Trạng thái: Chưa nhận được nhiệm vụ"
            break
        end
    end
end)
